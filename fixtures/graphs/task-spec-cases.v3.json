      "outputContract": {
        "ports": [
          {
            "name": "result",
            "jsonSchema": {
              "type": "object"
            }
          }
        ]
      },
      "policy": {}
    },
    {
      "id": "artifact-1",
      "node_type": "ARTIFACT",
      "title": "輸出報告"
